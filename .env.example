# ─── DevLens Lite · Environment Variables ─────────────────────────────────────

# ── Backend ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# MongoDB
MONGO_URI=mongodb://localhost:27017/devlens

# JWT  (generate with: node -e "require('crypto').randomBytes(64).toString('hex')|xargs echo")
JWT_SECRET=replace_with_64_char_random_hex
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_different_64_char_random_hex
JWT_REFRESH_EXPIRES_IN=7d

# Gemini AI  (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Clone directory (must be writable)
CLONE_DIR=/tmp/repos

# CORS
FRONTEND_URL=http://localhost:3000

# Email (for forgot-password) – optional, uses Ethereal in dev if omitted
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@devlens.io

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:4000/api/v1
